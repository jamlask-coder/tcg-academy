# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
# Screenshots generados por tests visuales (artefactos locales, no commitear).
/tests/visual/out/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# backups locales — pueden contener PII histórica + configuración sensible.
# Generados por scripts/backup.js y `npm run backup`. Nunca al repositorio.
/backups/

# audit handoff transitorio (memoria de sesiones de auditoría)
/.claude/audit-handoff.md

# Python price tracker — datos locales, cache y bytecode
__pycache__/
*.pyc
*.pyo
.python-version
/scripts/price_tracker/data/
*.duckdb
*.duckdb.wal

.vercel
