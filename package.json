{
  "name": "tcg-academy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test:visual": "playwright test tests/visual/",
    "test:a11y": "playwright test tests/a11y/",
    "test:all": "npm run lint && npm run typecheck && npm run build && npm run test:visual",
    "audit": "npm audit",
    "analyze": "cross-env ANALYZE=true npm run build",
    "optimize:images": "node scripts/optimize-images.js",
    "backup": "node scripts/backup.js",
    "backup:auto": "node scripts/backup.js --auto",
    "restore": "node scripts/restore.js",
    "check:all": "npm run lint && npm run format && npm run typecheck && npm run build && npm run audit",
    "test:layout": "playwright test tests/visual/",
    "test:overlap": "playwright test tests/visual/overlap-detection.spec.ts",
    "test:overflow": "npx ts-node --project tsconfig.json tests/visual/check-overflow.ts",
    "prepare": "husky",
    "warnings:count": "node scripts/count-warnings.mjs",
    "warnings:baseline": "node scripts/count-warnings.mjs --baseline",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "quality:gate": "npm run lint && npm run typecheck && npm run test:unit && npm run warnings:count"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --no-warn-ignored"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-oauth/google": "^0.13.5",
    "@supabase/supabase-js": "^2.103.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "flag-icons": "^7.5.0",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.1",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axe-core": "^4.11.1",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "serve": "^14.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
